{
  "name": "specshub",
  "version": "0.0.2",
  "description": "specshub — per-context AI agent docs hubs with spec-driven workflow skills. CLI: init, link, verify, unlink, list, status, doctor.",
  "type": "module",
  "bin": {
    "specshub": "dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "pnpm build"
  },
  "keywords": [
    "docs",
    "documentation",
    "ai-agents",
    "claude-code",
    "obsidian",
    "monorepo",
    "knowledge-base"
  ],
  "author": "Sumit Patel",
  "license": "MIT",
  "homepage": "https://github.com/Sumit1993/specshub",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Sumit1993/specshub.git"
  },
  "bugs": {
    "url": "https://github.com/Sumit1993/specshub/issues"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.2.1",
    "commander": "^12.1.0",
    "ora": "^8.1.1",
    "picocolors": "^1.1.1",
    "tar": "^7.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/tar": "^6.1.13",
    "tsup": "^8.3.5",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
